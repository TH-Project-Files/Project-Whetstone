{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whetstone.kit/schemas/cluster.schema.json",
  "title": "IssueCluster",
  "description": "A group of findings sharing a root cause. Produced by the Root-Cause Analyst (roles/05-root-cause-analyst.md). Persisted in workspace/<campaign>/memory/issue_clusters.json (rewritten each round; the underlying findings stay append-only). Ranked by severity x prevalence x leverage, minus regression risk.",
  "type": "object",
  "required": ["cluster_id", "title", "issue_class", "member_findings", "aggregate", "rank_score"],
  "additionalProperties": false,
  "properties": {
    "cluster_id": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "issue_class": {
      "type": "string",
      "enum": ["routing-defect", "missing-tool", "weak-tool-contract", "insufficient-stop-condition", "stale-data-mishandling", "source-precedence-confusion", "ambiguity-resolution", "confidence-provenance", "security-hardening-gap", "prompt-injection-susceptibility", "cost-explosion", "memory-context-misuse", "escalation-failure", "unsupported-synthesis", "policy-contradiction", "instruction-following-failure", "hallucination", "other"]
    },
    "affected_modes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["efficiency", "tool-coverage", "agent-logic", "stall-conditions", "security", "behavioral-hardening", "prompt-injection", "instruction-following"]
      }
    },
    "member_findings": { "type": "array", "minItems": 1, "items": { "type": "string" }, "description": "Finding ids in this cluster." },
    "representative_examples": { "type": "array", "items": { "type": "string" }, "description": "Scenario ids that best illustrate it." },
    "aggregate": {
      "type": "object",
      "required": ["severity", "prevalence", "improvement_leverage"],
      "additionalProperties": false,
      "properties": {
        "severity": { "type": "number", "minimum": 1, "maximum": 5, "description": "Aggregate severity across members." },
        "prevalence": { "type": "number", "minimum": 0, "maximum": 1, "description": "Fraction of scenarios showing this cluster; the empirical, not estimated, rate once samples suffice." },
        "improvement_leverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "regression_risk": { "type": "integer", "minimum": 1, "maximum": 5 },
        "min_fidelity": { "type": "string", "enum": ["L0", "L1", "L2", "L3"], "description": "Lowest fidelity among members; a cluster seen only at L0 is a prediction, not a confirmed defect." },
        "confirmed_members": { "type": "integer", "minimum": 0 }
      }
    },
    "likely_root_cause": { "type": "string" },
    "fix_locus": {
      "type": "string",
      "enum": ["prompt-policy", "tool-contract", "routing-logic", "stop-conditions", "source-precedence", "confidence-framework", "memory-handling", "security-guardrail", "ux-expectation", "new-tool"]
    },
    "rank_score": { "type": "number", "description": "severity x prevalence x improvement_leverage, discounted by regression_risk and low fidelity. Higher = fix sooner." },
    "stability": {
      "type": "object",
      "description": "Cross-round persistence; a cluster that recurs is more trustworthy than a one-round blip.",
      "additionalProperties": false,
      "properties": {
        "first_seen_round": { "type": "integer", "minimum": 0 },
        "rounds_observed": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
